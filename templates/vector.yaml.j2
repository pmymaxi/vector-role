sources:
  nginx_logs:
    type: file
    include:
      - "{{ vector_include_logs }}"

sinks:
  clickhouse:
    type: clickhouse
    inputs:
      - nginx_logs
    endpoint: "http://{{ vector_clickhouse_http_host }}:{{ vector_clickhouse_http_port }}"
    database: "{{ vector_clickhouse_db_name }}"
    table: "{{ vector_clickhouse_table_name }}"
    skip_unknown_fields: true
    auth:
      strategy: basic
      user: ${CLICKHOUSE_USER}
      password: ${CLICKHOUSE_PASSWORD}
